# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.open-next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# cloudflare
.wrangler/

# typescript
*.tsbuildinfo
next-env.d.ts

# 故事音频：现有已入库的这批保留追踪（gitignore 不影响已跟踪文件）；
# 后续批量生成的音频默认忽略 —— 先本地试听，确认后统一上传 Supabase Storage，由代码引用，不入 git。
/public/audio/*
!/public/audio/.gitkeep

# 故事封面：由 scripts/upload-assets.mjs 抓取生成，本地直读用；生产走 Supabase Storage。不入 git。
/public/covers/
